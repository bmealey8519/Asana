<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="Asana2.Maui.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:Asana2.Maui"
    xmlns:views="clr-namespace:Asana2.Maui.Views"
    Shell.FlyoutBehavior="Disabled"
    Title="Asana2.Maui">

    <ShellContent
        Title="Home"
        ContentTemplate="{DataTemplate local:MainPage}"
        Route="MainPage" />
    <ShellContent
        Title="ToDo Details"
        ContentTemplate="{DataTemplate views:ToDoDetailView}"
        Route="ToDoDetails" />

</Shell>
